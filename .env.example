# ─────────────────────────────────────────────────────────────────
#  SmartFarm AI  –  Environment Variables Template
#  Copy this file to ".env" and fill in your real credentials.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────

# ── IBM watsonx.ai ───────────────────────────────────────────────
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=
# ── IBM Granite model IDs (change if you want a different version)
GRANITE_LLM_MODEL=ibm/granite-4-h-small
GRANITE_EMBED_MODEL=ibm/slate-125m-english-rtrvr

# ── OpenWeatherMap ────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ── data.gov.in  (Agmarknet mandi prices) ────────────────────────
DATAGOVIN_API_KEY=your_data_gov_in_api_key_here

# ── Flask ─────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
FLASK_DEBUG=false
FLASK_PORT=5001

# ── ChromaDB persistence directory ───────────────────────────────
CHROMA_PERSIST_DIR=./chromadb_store

# ── Knowledge-base source directory ──────────────────────────────
KB_DIR=./knowledge_base
